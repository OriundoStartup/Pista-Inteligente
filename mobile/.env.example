# ─── Pista Inteligente — Mobile App Environment Variables ───
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables prefixed with EXPO_PUBLIC_ are accessible in the app bundle.
# Never commit your real .env file to version control.

# ─── Supabase (REQUIRED) ───
# Your Supabase project URL (from Supabase Dashboard > Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://bxdxztbdsxyyvvavvtoo.supabase.co

# Supabase anonymous/public key (from Supabase Dashboard > Settings > API > anon key)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ4ZHh6dGJkc3h5eXZ2YXZ2dG9vIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjgzNTQxNzcsImV4cCI6MjA4MzkzMDE3N30.J6hbXS2bAcqMy0ZGdnZw-HxDJMX4QtdUAyJuwgP7Bm4

# ─── API Backend (RECOMMENDED) ───
# Base URL of the Next.js frontend (used by chatbot and análisis
# Without trailing slash
EXPO_PUBLIC_API_BASE_URL=https://pista-inteligente.vercel.app

# ─── Donation (OPTIONAL) ───
# Payment link for the "Invítanos una Quinela" button
# If empty or missing, the donation button won't appear
EXPO_PUBLIC_DONATION_URL=https://link.mercadopago.cl/pistainteligente
